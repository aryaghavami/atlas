# Plaid (read-only bank data) — keys at dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Plaid OAuth redirect (your deployed URL + /atlas/accounts), needed for OAuth banks
PLAID_REDIRECT_URI=

# Supabase (storage) — Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Your private passcode that gates the real-data routes (/atlas/live, /admin)
ATLAS_PASSWORD=

# Optional: ntfy.sh topic for signup push notifications (if you run the email funnel)
ATLAS_NTFY_TOPIC=
