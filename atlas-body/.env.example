# Atlas · Body — environment

# Password gate for your real data in production (the public demo stays open).
# Leave unset in local dev to skip the gate.
ATLAS_BODY_PASSWORD=

# Supabase (storage). Optional locally — without it, state falls back to a local
# file at .data/body.json. Required to persist on serverless (Vercel).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Withings OAuth (smart-scale sync). Optional — manual weigh-ins work without it.
# Create an app at https://developer.withings.com
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:3000/api/withings/callback
